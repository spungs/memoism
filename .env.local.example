# Database
# - 로컬 PostgreSQL: 아래 주석된 줄 사용
# - Supabase: Dashboard → Project Settings → Database → Connection string
#   * DATABASE_URL: "Transaction pooler" (port 6543) — runtime용
#   * DIRECT_URL : "Direct connection" (port 5432) — 마이그레이션용
# 두 URL 모두 끝에 ?schema=app 붙여야 한다 (단일 스키마 모드).
# DATABASE_URL="postgresql://memoism:memoism@localhost:5432/memoism?schema=app"
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?schema=app&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?schema=app"

# JWT signing key for session cookies. Generate with: openssl rand -base64 32
# Rotating this value invalidates all existing sessions.
JWT_SECRET="replace-me-with-a-32-byte-random-string"

# AI Chat (Ollama 로컬 모델)
# Ollama 실행 후 `ollama pull gemma4:e2b` 로 모델 다운로드
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="gemma4:e2b"
