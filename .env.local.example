# =============================================================================
# Memoism — 환경변수 예시 (베타)
# =============================================================================
# 이 파일은 git에 포함됩니다. 실제 값은 .env.local 또는 Vercel 환경변수에 입력.
# 모든 시크릿은 .env.local에만 보관 (gitignore됨).

# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# -----------------------------------------------------------------------------
# Dashboard → Project Settings → Database → Connection string
#   - DATABASE_URL: "Transaction pooler" (port 6543) — runtime
#   - DIRECT_URL  : "Direct connection" (port 5432) — 마이그레이션
# 두 URL 모두 끝에 ?schema=app 필수 (단일 스키마 모드)
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?schema=app&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?schema=app"

# -----------------------------------------------------------------------------
# Session
# -----------------------------------------------------------------------------
# 32바이트 랜덤 키. 생성: openssl rand -base64 32
# 회전 시 모든 기존 세션 무효화됨 (의도된 동작).
JWT_SECRET="replace-me-with-a-32-byte-random-string"

# -----------------------------------------------------------------------------
# Supabase Storage (이미지 저장 — Phase 2에서 활성화)
# -----------------------------------------------------------------------------
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
# 버킷 이름 (private 버킷)
SUPABASE_STORAGE_BUCKET="diary-images"

# -----------------------------------------------------------------------------
# AI — Gemini 2.5 Flash (Phase 2에서 활성화, Ollama 대체)
# -----------------------------------------------------------------------------
# 발급: https://aistudio.google.com → API keys
# 베타 단계: 결제 수단 미등록 권장 (한도 초과 시 throttle, 비용 0)
GEMINI_API_KEY="<your-gemini-api-key>"
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"

# -----------------------------------------------------------------------------
# Web Push (Phase 5 NEW-15 — 22:00 KST 리마인드)
# -----------------------------------------------------------------------------
# 생성: npx -y web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="<vapid-public-key>"
VAPID_PRIVATE_KEY="<vapid-private-key>"
VAPID_SUBJECT="mailto:admin@memoism.app"
