# Database — local PostgreSQL (via docker-compose) by default.
# To switch to Supabase later, replace this with the connection string from
# Supabase Dashboard → Project Settings → Database → Connection string (URI).
# Use the "Transaction pooler" (port 6543) URL for serverless deployments.
DATABASE_URL="postgresql://memoism:memoism@localhost:5432/memoism?schema=public"
