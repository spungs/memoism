# Database — local PostgreSQL (via docker-compose or Homebrew) by default.
# To switch to Supabase later, replace this with the connection string from
# Supabase Dashboard → Project Settings → Database → Connection string (URI).
# Use the "Transaction pooler" (port 6543) URL for serverless deployments.
DATABASE_URL="postgresql://memoism:memoism@localhost:5432/memoism?schema=app"

# JWT signing key for session cookies. Generate with: openssl rand -base64 32
# Rotating this value invalidates all existing sessions.
JWT_SECRET="replace-me-with-a-32-byte-random-string"
