// Prisma schema — see https://pris.ly/d/prisma-schema
// Datasource uses DATABASE_URL so we can switch from local Postgres to Supabase
// (or any other Postgres-compatible host) by changing the connection string only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  diaries      Diary[]
  chatMessages ChatMessage[]

  @@map("users")
}

model Diary {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  content   String
  images    String[]
  location  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("diaries")
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  role      String
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("chat_messages")
}
