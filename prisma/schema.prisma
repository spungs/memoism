// Prisma schema — see https://pris.ly/d/prisma-schema
//
// Datasource uses DATABASE_URL so we can switch from local Postgres to Supabase
// (or any other Postgres-compatible host) by changing the connection string.
// The `?schema=app` query param in DATABASE_URL routes every model to the `app`
// schema — no @@schema annotations needed (single-schema mode).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // PgBouncer (Supabase pooled URL)는 prepared statement를 못 다루므로
  // 마이그레이션은 directUrl을 통해 5432 포트 직접 연결로 실행한다.
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum SubscriptionStatus {
  NONE
  TRIAL
  ACTIVE
  EXPIRED
}

// =============================================================================
// Account & user-owned content
// =============================================================================

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  passwordHash       String?  @map("password_hash")
  googleSub          String?  @unique @map("google_sub")
  externalLLMConsent Boolean  @default(false) @map("external_llm_consent")
  // tokenVersion — 세션 무효화 카운터 (QA M-10). JWT payload에 담고 getSession에서
  // DB 값과 비교. 비밀번호 변경 시 increment → 발급된 기존 토큰 전부 무효.
  tokenVersion       Int      @default(0) @map("token_version")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  character         Character?
  persona           UserPersona?
  diaries           Diary[]
  chatMessages      ChatMessage[]
  usageLogs         UsageLog[]
  pushSubscriptions PushSubscription[]

  @@map("users")
}

// UserPersona — AI 본문 생성의 톤·길이·말투 결정.
//   - 베타엔 기본값 row만 사용 (UI 미노출).
//   - V2에서 프리셋 선택·커스텀 UI 도입.
model UserPersona {
  userId         String   @id @map("user_id")
  presetKey      String   @default("factual") @map("preset_key")
  tone           String   @default("warm")
  formality      String   @default("casual")
  sentenceLength String   @default("medium") @map("sentence_length")
  perspective    String   @default("first")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_personas")
}

// =============================================================================
// Diary
//   - source: "manual" / "auto_a" (사진→본문) / "auto_b" (텍스트→정리) / "auto_c" (둘 다)
//   - previousContent / previousChangedAt: 백업 스왑 슬롯 (직전 1개만 보관)
//   - aiGenerationVersion: AI 재생성 누적 카운터 (재생성 cap 5회 검증용)
//   - images: 1:N DiaryImage로 분리
//   - location/mood: 베타 미사용 (V2 재활성 가능성에 컬럼 보존)
// =============================================================================

model Diary {
  id                  String    @id @default(uuid())
  userId              String    @map("user_id")
  title               String
  content             String
  previousContent     String?   @map("previous_content")
  previousChangedAt   DateTime? @map("previous_changed_at")
  source              String    @default("manual")
  aiGenerationVersion Int       @default(0) @map("ai_generation_version")
  contentEditedAt     DateTime? @map("content_edited_at")
  location            Json?     // deprecated, DiaryImage.exifLat/Lng로 흡수
  mood                String?   // deprecated, V2 재활성 가능
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  images    DiaryImage[]
  embedding DiaryEmbedding?

  @@index([userId, createdAt(sort: Desc)])
  @@map("diaries")
}

// DiaryImage — 일기당 최대 5장. EXIF 메타데이터 포함.
//   - storagePath: Supabase Storage 'diary-images' 버킷 내 경로
//   - exifLat/Lng: B-1.smart 정책 (EXIF 있는 사진끼리 같은 KST 날짜 검증)
//   - orderIndex: 사용자가 업로드한 순서 보존
model DiaryImage {
  id          String    @id @default(uuid())
  diaryId     String    @map("diary_id")
  storagePath String    @map("storage_path")
  exifTakenAt DateTime? @map("exif_taken_at")
  exifLat     Float?    @map("exif_lat")
  exifLng     Float?    @map("exif_lng")
  orderIndex  Int       @default(0) @map("order_index")
  createdAt   DateTime  @default(now()) @map("created_at")

  diary Diary @relation(fields: [diaryId], references: [id], onDelete: Cascade)

  @@index([diaryId, orderIndex])
  @@map("diary_images")
}

// DiaryEmbedding — pgvector 768d (Gemini text-embedding-004).
//   - createDiary/updateDiary 성공 후 비동기 임베딩 생성.
//   - Prisma는 vector 타입 미지원 → Unsupported, raw SQL로 접근.
model DiaryEmbedding {
  diaryId   String                     @id @map("diary_id")
  vector    Unsupported("vector(768)")
  updatedAt DateTime                   @updatedAt @map("updated_at")

  diary Diary @relation(fields: [diaryId], references: [id], onDelete: Cascade)

  @@map("diary_embeddings")
}

// UsageLog — 일일 AI 호출 cap 추적 (3중 abuse cap).
//   - 무료 3 / Basic 10 / Pro 100 (Pro는 V2)
//   - 동시성: upsert + 조건부 increment (WHERE ai_call_count < limit)
model UsageLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  date        DateTime @db.Date
  aiCallCount Int      @default(0) @map("ai_call_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("usage_logs")
}

// =============================================================================
// Character — "친구" 페르소나 (Basic+ RAG 채팅 인터페이스)
//   D-1/D-2/D-3 폐기 결정 반영 (게임화 컬럼 드롭 완료):
//   - 게임화(age/bornAt/isAsleep/coinBalance/trialStartedAt) + 개별 이름(name) 컬럼 제거.
//     캐릭터 이름은 전역 시그니처 "메이"로 고정 (CHARACTER_NAME in lib/character/utils.ts).
//   - subscriptionStatus: 베타 사용자 전원 ACTIVE 자동 부여 (구독 도메인은 유지).
//   - 외형 관계(CharacterOutfit/Owned/Equipped) 모두 삭제.
// =============================================================================

model Character {
  id                    String             @id @default(uuid())
  userId                String             @unique @map("user_id")
  subscriptionStatus    SubscriptionStatus @default(ACTIVE) @map("subscription_status")
  subscriptionExpiresAt DateTime?          @map("subscription_expires_at")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatMessages ChatMessage[]

  @@index([subscriptionStatus, subscriptionExpiresAt])
  @@map("characters")
}

// ChatMessage — 캐릭터 친구와의 대화 (Basic+ RAG 결과 포함).
//   - 24h 보존 정책 (pg_cron으로 자동 삭제)
//   - characterId 비정규화: 사용자→캐릭터 join 없이 직접 조회
model ChatMessage {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  characterId String      @map("character_id")
  role        MessageRole
  content     String
  createdAt   DateTime    @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, createdAt])
  @@index([userId, createdAt])
  @@map("chat_messages")
}

// PushSubscription — Web Push 구독 (22:00 KST 리마인드, NEW-15).
//   - 한 사용자가 여러 기기 구독 가능 (endpoint별 1행).
//   - endpoint 고유: 같은 기기 재구독 시 upsert로 갱신.
//   - iOS는 PWA 설치 + iOS 16.4+ 에서만 Web Push 수신 가능.
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}
